<Window x:Class="VoiceInputApp.Windows.HudWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:controls="clr-namespace:VoiceInputApp.Controls"
        Title="Voice Input HUD"
        Width="Auto"
        Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Topmost="True">

    <Window.Resources>
        <Style x:Key="HudContainer" TargetType="Border">
            <Setter Property="Background" Value="#A51A1C1E"/> <!-- Semi-transparent dark -->
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#2AFFFFFF"/> <!-- Glass highlight -->
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="HudShell"
                Style="{StaticResource HudContainer}"
                HorizontalAlignment="Center"
                MinWidth="380"
                MaxWidth="600"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="HudScaleTransform" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="HudTranslateTransform" Y="0"/>
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect BlurRadius="32"
                                  ShadowDepth="8"
                                  Opacity="0.32"
                                  Direction="270"
                                  Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.RowSpan="2"
                        CornerRadius="2"
                        Background="{Binding State, Converter={StaticResource HudStateToBrushConverter}}"
                        Opacity="0.9"/>

                <Grid Grid.Column="2" Width="44" Height="32" VerticalAlignment="Center">
                    <Ellipse x:Name="StateDot"
                            Width="8"
                            Height="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Fill="{Binding State, Converter={StaticResource HudStateToBrushConverter}}"/>
                    <controls:WaveformControl Width="44"
                                              Height="32"
                                              Levels="{Binding WaveformLevels, Mode=OneWay}"
                                              Visibility="{Binding State, Converter={StaticResource StateToVisibilityConverter}, ConverterParameter=Listening}"/>
                </Grid>

                <TextBlock x:Name="DisplayTextBlock"
                           Grid.Column="4"
                           Text="{Binding DisplayText}"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MaxWidth="500"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
