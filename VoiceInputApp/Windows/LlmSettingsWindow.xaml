<Window x:Class="VoiceInputApp.Windows.LlmSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LLM Refinement 设置"
        Width="450"
        Height="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="API Base URL:" Margin="0,0,0,5"/>
            <TextBox x:Name="BaseUrlBox" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="API Key:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ApiKeyBox" Padding="5" PasswordChanged="ApiKeyBox_PasswordChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Model:" Margin="0,0,0,5"/>
            <TextBox x:Name="ModelBox" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="Gray" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Test" Command="{Binding TestCommand}" Width="70" Margin="0,0,10,0" Padding="5"
                    IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="Save" Command="{Binding SaveCommand}" Width="70" Margin="0,0,10,0" Padding="5"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="70" Padding="5"/>
        </StackPanel>
    </Grid>
</Window>
