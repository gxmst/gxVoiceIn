<Window x:Class="VoiceInputApp.Windows.ControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="语音控制台"
        Width="920"
        Height="680"
        MinWidth="820"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="22"
                Background="#FF1F2937"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="语音输入与语音对话"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                    <TextBlock Text="在这里切换输入 / 对话 / 混合模式，查看最近识别内容和助手回复。"
                               Margin="0,8,0,0"
                               Foreground="#D1D5DB"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        VerticalAlignment="Top"
                        Background="#1FFFFFFF"
                        CornerRadius="16">
                    <TextBlock x:Name="UpdatedAtText"
                               Foreground="#E5E7EB"
                               FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2"
                     Columns="4"
                     HorizontalAlignment="Stretch">
            <Border Margin="0,0,12,0"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="运行模式"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock x:Name="ModeText"
                               Margin="0,10,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="输入"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="SetInputMode_Click"/>
                        <Button Content="对话"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="SetConversationMode_Click"/>
                        <Button Content="混合"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="SetHybridMode_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Margin="0,0,12,0"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="当前状态"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock x:Name="CurrentStateText"
                               Margin="0,10,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="PlaybackStateText"
                               Margin="0,8,0,0"
                               Foreground="#374151"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="HotkeyInfoText"
                               Margin="0,6,0,0"
                               Foreground="#6B7280"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="LanguageInfoText"
                               Margin="0,4,0,0"
                               Foreground="#6B7280"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,12,0"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="ASR / LLM"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock x:Name="AsrStatusText"
                               Margin="0,10,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="LlmModelText"
                               Margin="0,8,0,0"
                               Foreground="#374151"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="ASR 设置"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="OpenAsrSettings_Click"/>
                        <Button Content="LLM 设置"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="OpenLlmSettings_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="快捷操作"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="停止播放"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="StopPlayback_Click"/>
                        <Button Content="清空会话"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="ClearConversation_Click"/>
                        <Button Content="打开日志目录"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="OpenLogFolder_Click"/>
                        <Button Content="刷新"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="Refresh_Click"/>
                        <Button Content="退出程序"
                                Margin="0,0,8,8"
                                Padding="12,8"
                                Click="Quit_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <Border Padding="18"
                    Background="White"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock Text="最近语音与回复"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock x:Name="ConversationTurnCountText"
                                   DockPanel.Dock="Right"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="最近识别"
                                   Foreground="#6B7280"
                                   FontSize="12"/>
                        <TextBox x:Name="RecognizedTextBox"
                                 Margin="0,6,0,0"
                                 Padding="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="72"
                                 Background="#F9FAFB"
                                 BorderBrush="#E5E7EB"/>
                        <TextBlock Text="助手回复"
                                   Margin="0,12,0,0"
                                   Foreground="#6B7280"
                                   FontSize="12"/>
                        <TextBox x:Name="AssistantReplyBox"
                                 Margin="0,6,0,0"
                                 Padding="12"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 MinHeight="92"
                                 Background="#F9FAFB"
                                 BorderBrush="#E5E7EB"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ConversationItemsControl">
                            <ItemsControl.Resources>
                                <DataTemplate x:Key="UserMessageTemplate">
                                    <Border Margin="0,4,24,4"
                                            Padding="12,8"
                                            Background="#EEF2FF"
                                            CornerRadius="12"
                                            HorizontalAlignment="Left"
                                            MaxWidth="420">
                                        <StackPanel>
                                            <TextBlock Text="你"
                                                       Foreground="#4F46E5"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="#1E1B4B"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding TimeDisplay}"
                                                       Foreground="#9CA3AF"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                                <DataTemplate x:Key="AssistantMessageTemplate">
                                    <Border Margin="24,4,0,4"
                                            Padding="12,8"
                                            Background="#F0FDF4"
                                            CornerRadius="12"
                                            HorizontalAlignment="Right"
                                            MaxWidth="420">
                                        <StackPanel>
                                            <TextBlock Text="助手"
                                                       Foreground="#16A34A"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="#14532D"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding TimeDisplay}"
                                                       Foreground="#9CA3AF"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"
                                                       HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.Resources>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="最近日志"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock x:Name="LogPathText"
                                   DockPanel.Dock="Right"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <TextBox x:Name="RecentLogsBox"
                             Grid.Row="2"
                             Padding="14"
                             Background="#F9FAFB"
                             BorderBrush="#E5E7EB"
                             Foreground="#111827"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
