<Window x:Class="VoiceInputApp.Windows.ControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="语音输入法控制台"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="22"
                Background="#FF1F2937"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="语音输入法控制台"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                    <TextBlock Text="双击托盘即可打开。在这里查看当前状态、进入设置和快速查看日志。"
                               Margin="0,8,0,0"
                               Foreground="#D1D5DB"
                               FontSize="14"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,8"
                        VerticalAlignment="Top"
                        Background="#1FFFFFFF"
                        CornerRadius="16">
                    <TextBlock x:Name="UpdatedAtText"
                               Foreground="#E5E7EB"
                               FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2"
                     Columns="4"
                     HorizontalAlignment="Stretch">
            <Border Margin="0,0,12,0"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="语音识别"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock x:Name="AsrStatusText"
                               Margin="0,10,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="LanguageText"
                               Margin="0,8,0,0"
                               Foreground="#374151"
                               FontSize="13"/>
                    <Button Content="打开 ASR 设置"
                            Margin="0,18,0,0"
                            Padding="14,10"
                            Background="#111827"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OpenAsrSettings_Click"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,12,0"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="文本修复"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock x:Name="LlmStatusText"
                               Margin="0,10,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="LlmModelText"
                               Margin="0,8,0,0"
                               Foreground="#374151"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <Button Content="打开 LLM 设置"
                            Margin="0,18,0,0"
                            Padding="14,10"
                            Background="#0F766E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="OpenLlmSettings_Click"/>
                </StackPanel>
            </Border>

            <Border Margin="0,0,12,0"
                    Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="启动设置"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock x:Name="AutoStartStatusText"
                               Margin="0,10,0,0"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="登录 Windows 后自动启动程序。"
                               Margin="0,8,0,0"
                               Foreground="#374151"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <Button x:Name="AutoStartButton"
                            Margin="0,18,0,0"
                            Padding="14,10"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ToggleAutoStart_Click"/>
                </StackPanel>
            </Border>

            <Border Padding="18"
                    Background="White"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock Text="快捷操作"
                               Foreground="#6B7280"
                               FontSize="13"/>
                    <TextBlock Text="查看日志、刷新状态或直接退出程序。"
                               Margin="0,10,0,0"
                               Foreground="#374151"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="打开日志目录"
                                Margin="0,0,8,8"
                                Padding="14,10"
                                Background="#E5E7EB"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="OpenLogFolder_Click"/>
                        <Button Content="刷新"
                                Margin="0,0,8,8"
                                Padding="14,10"
                                Background="#DBEAFE"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Refresh_Click"/>
                        <Button Content="退出程序"
                                Margin="0,0,8,8"
                                Padding="14,10"
                                Background="#FEE2E2"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="Quit_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="4"
                Padding="18"
                Background="White"
                CornerRadius="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Text="最近日志"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock x:Name="LogPathText"
                               DockPanel.Dock="Right"
                               Foreground="#6B7280"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <TextBox x:Name="RecentLogsBox"
                         Grid.Row="2"
                         Padding="14"
                         Background="#F9FAFB"
                         BorderBrush="#E5E7EB"
                         Foreground="#111827"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
