<Window x:Class="VoiceInputApp.Windows.AsrSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ASR 设置 - 大模型流式语音识别"
        Width="420"
        Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <DockPanel Margin="24" LastChildFill="True" Background="#1E1E1E">
        <TextBlock DockPanel.Dock="Top" Text="语音识别配置" Style="{StaticResource HeaderStyle}"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="打开日志" Command="{Binding OpenLogCommand}" Width="80" Margin="0,0,12,0"/>
            <Button Content="测试" Command="{Binding TestCommand}" Width="80" Margin="0,0,12,0"
                    IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="保存" Command="{Binding SaveCommand}" Width="80" Margin="0,0,12,0"/>
            <Button Content="取消" Command="{Binding CancelCommand}" Width="80"/>
        </StackPanel>

        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="麦克风:" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Microphones}"
                              SelectedValue="{Binding SelectedMicrophoneIndex}"
                              SelectedValuePath="Index"
                              DisplayMemberPath="Name"
                              Padding="5"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="触发键 (十进制数字):" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding TriggerKey, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    <TextBlock Text="常用键: RShift (161), CapsLock (20), LAlt (164)"
                               Foreground="Gray" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="AppID:" Margin="0,0,0,4"/>
                    <TextBox x:Name="AppIdBox" Text="{Binding AppId, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Token:" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TokenBox" Padding="5" PasswordChanged="TokenBox_PasswordChanged"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Resource ID:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ResourceId, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    <TextBlock Text="小时版: volc.bigasr.sauc.duration  并发版: volc.bigasr.sauc.concurrent"
                               Foreground="Gray" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Model Name:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    <TextBlock Text="默认推荐 bigmodel，偏输入法体验。"
                               Foreground="Gray" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="热词表 ID（可选）:" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding BoostingTableId, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>
                    <TextBlock Text="如果你在火山侧配置了热词表，把 ID 填这里，专业词和术语会更稳。"
                               Foreground="Gray" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" Margin="0,0,0,4"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
